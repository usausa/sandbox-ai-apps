@page "/"
@rendermode InteractiveServer

<PageTitle>InspectorChecker</PageTitle>

<div class="ic">
    <div class="ic-actions">
        <div class="ic-dropzone-shell">
            <label class="ic-dropzone @(isBusy ? "is-busy" : string.Empty)"
                   title="担当者1名分の30日調査CSVをアップロード"
                   @ref="dropZoneRef">
                <div class="ic-dropzone-icon">
                    <i class="bi bi-file-earmark-arrow-up"></i>
                </div>
                <div class="ic-dropzone-copy">
                    <strong>調査CSVをアップロード</strong>
                    <span>クリックして選択、またはこのエリアへCSVをドラッグ＆ドロップ</span>
                </div>
                <InputFile @key="inputFileKey" OnChange="OnCsvFileChangedAsync" accept=".csv,text/csv" class="ic-upload-input" disabled="@isBusy" />
            </label>
        </div>
        @if (result is not null && !isBusy)
        {
            <button type="button" class="btn-se-ghost" @onclick="ClearAsync">
                <i class="bi bi-trash3"></i>
                <span>結果をクリア</span>
            </button>
        }
        @if (isBusy)
        {
            <button type="button" class="btn-se-ghost" @onclick="CancelAsync">
                <i class="bi bi-stop-circle"></i>
                <span>キャンセル</span>
            </button>
        }
    </div>

    @if (errorMessage is not null)
    {
        <div class="fb-error-toast">
            <i class="bi bi-exclamation-circle"></i>
            <span>@errorMessage</span>
            <button type="button" class="btn-se-icon" @onclick="() => errorMessage = null">
                <i class="bi bi-x"></i>
            </button>
        </div>
    }

    @if (isBusy)
    {
        <div class="ig-progress">
            <div class="spinner-se spinner-se-lg" role="status"></div>
            <span class="ig-progress-message">@progressMessage</span>
        </div>
    }

    <div class="ic-content">
        @if (result is null)
        {
            <section class="ic-empty">
                <div class="ic-empty-icon">
                    <i class="bi bi-shield-exclamation"></i>
                </div>
                <h1>漏れ電流の巡回調査から不正入力パターンを検出</h1>
                <p>
                    CSVをアップロードすると、漏れ電流の値分布と日別の集中度を先に整理し、
                    その要約と生データを Foundry の LLM に渡して不正確率を判定します。
                </p>
                <div class="ic-empty-format">
                    CSV列は <code>InvestigationDate,CustomerId,Current</code> です。判定基準は漏れ電流 1mA 未満。
                </div>
            </section>

            <section class="ic-section">
                <div class="ic-section-header">
                    <div>
                        <h2>デモ用サンプルCSV</h2>
                        <p>正常2種、不正2種を用意しています。ローカルで保存してからアップロードしてください。</p>
                    </div>
                </div>
                <div class="ic-sample-grid">
                    @foreach (var sample in SampleFiles)
                    {
                        <a class="ic-sample-card" href="@sample.Url" download="@sample.FileName">
                            <span class="ic-sample-kind @sample.KindClass">@sample.KindLabel</span>
                            <strong>@sample.Title</strong>
                            <span>@sample.Description</span>
                        </a>
                    }
                </div>
            </section>
        }
        else
        {
            <section class="ic-overview">
                <article class="ic-score-card @GetScoreClass(result.Analysis.OverallScore)">
                    <span class="ic-score-label">不正確率</span>
                    <strong class="ic-score-value">@result.Analysis.OverallScore</strong>
                    <span class="ic-score-unit">/ 100</span>
                    <p>@GetScoreCaption(result.Analysis.OverallScore)</p>
                </article>

                <article class="ic-stat-card">
                    <h2>アップロード概要</h2>
                    <dl class="ic-stat-list">
                        <div><dt>ファイル</dt><dd>@result.UploadedFileName</dd></div>
                        <div><dt>行数</dt><dd>@result.FeatureSummary.RecordCount.ToString("N0")</dd></div>
                        <div><dt>顧客数</dt><dd>@result.FeatureSummary.CustomerCount.ToString("N0")</dd></div>
                        <div><dt>期間</dt><dd>@result.FeatureSummary.StartDate.ToString("yyyy-MM-dd") ～ @result.FeatureSummary.EndDate.ToString("yyyy-MM-dd")</dd></div>
                        <div><dt>トークン</dt><dd>@FormatTokens(result.Usage)</dd></div>
                        <div><dt>概算費用</dt><dd>@FormatCost(result.Usage)</dd></div>
                    </dl>
                </article>

                <article class="ic-stat-card ic-summary-card">
                    <h2>LLMサマリー</h2>
                    <p>@result.Analysis.Summary</p>
                    <div class="ic-recommendation">
                        <i class="bi bi-lightbulb"></i>
                        <span>@result.Analysis.RecommendedAction</span>
                    </div>
                </article>
            </section>

            @if (result.Analysis.SuspiciousPatterns.Count > 0)
            {
                <section class="ic-section">
                    <div class="ic-section-header">
                        <div>
                            <h2>注目されたパターン</h2>
                            <p>LLM が不正兆候として重視した特徴です。</p>
                        </div>
                    </div>
                    <div class="ic-pattern-list">
                        @foreach (var pattern in result.Analysis.SuspiciousPatterns)
                        {
                            <span class="ic-pattern-chip">@pattern</span>
                        }
                    </div>
                </section>
            }

            <section class="ic-section">
                <div class="ic-section-header">
                    <div>
                        <h2>日別スコア</h2>
                        <p>高スコア日から並べています。日単位の再確認対象をここで絞り込めます。</p>
                    </div>
                </div>
                <div class="ic-table-wrap">
                    <table class="ic-table">
                        <thead>
                            <tr>
                                <th>日付</th>
                                <th class="ic-col-score">スコア</th>
                                <th>機械集計の特徴</th>
                                <th>疑わしい顧客</th>
                                <th>LLM理由</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var day in result.Analysis.DailyResults)
                            {
                                var feature = GetDailyFeature(day.InvestigationDate);
                                <tr class="@GetRowClass(day.Score)">
                                    <td>@day.InvestigationDate.ToString("yyyy-MM-dd")</td>
                                    <td class="ic-col-score">
                                        <span class="ic-score-pill @GetScoreClass(day.Score)">@day.Score</span>
                                    </td>
                                    <td>
                                        @if (feature is not null)
                                        {
                                            <div class="ic-feature-stack">
                                                <span>重複率 @FormatPercent(feature.DuplicateRatio)</span>
                                                <span>0.97mA集中 @FormatPercent(feature.NearDefaultRatio)</span>
                                                <span>日内SD @feature.StandardDeviation.ToString("0.000")</span>
                                                <span>最多値 @feature.MostCommonCurrent × @feature.MostCommonCurrentCount</span>
                                                @if (feature.HasRepeatedTemplate)
                                                {
                                                    <span>テンプレート再登場あり</span>
                                                }
                                            </div>
                                        }
                                    </td>
                                    <td>
                                        @if (day.SuspiciousCustomerIds.Count == 0)
                                        {
                                            <span class="ic-muted">-</span>
                                        }
                                        else
                                        {
                                            <span>@string.Join(", ", day.SuspiciousCustomerIds)</span>
                                        }
                                    </td>
                                    <td>@day.Reason</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </section>

            <section class="ic-detail-grid">
                <section class="ic-section">
                    <div class="ic-section-header">
                        <div>
                            <h2>電流値の分布</h2>
                            <p>特定の値（特に1mA直下の0.97mA付近）へ件数が偏るほど、まとめ入力の兆候として見やすくなります。</p>
                        </div>
                    </div>
                    <div class="ic-table-wrap">
                        <table class="ic-table">
                            <thead>
                                <tr>
                                    <th>電流値</th>
                                    <th>件数</th>
                                    <th>構成比</th>
                                    <th>判定</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var value in result.FeatureSummary.ValueDistribution.Take(15))
                                {
                                    <tr>
                                        <td>@value.Current.ToString("0.00")mA</td>
                                        <td>@value.Count.ToString("N0")</td>
                                        <td>@FormatPercent(value.Ratio)</td>
                                        <td>
                                            @if (value.Current >= 1.0)
                                            {
                                                <span class="ic-pattern-chip">基準超過</span>
                                            }
                                            else if (IsNearDefault(value.Current))
                                            {
                                                <span class="ic-pattern-chip">既定値付近</span>
                                            }
                                            else
                                            {
                                                <span class="ic-muted">-</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    @if (result.FeatureSummary.ValueDistribution.Count > 15)
                    {
                        <div class="ic-placeholder">ほか @((result.FeatureSummary.ValueDistribution.Count - 15).ToString("N0")) 種類の値があります。</div>
                    }
                </section>

                <section class="ic-section">
                    <div class="ic-section-header">
                        <div>
                            <h2>再利用された日次テンプレート</h2>
                            <p>完全一致の並びが複数日に再出現すると、実地調査なしの転記を疑いやすくなります。</p>
                        </div>
                    </div>
                    @if (result.FeatureSummary.RepeatedDailyTemplates.Count == 0)
                    {
                        <div class="ic-placeholder">完全一致のテンプレート再利用は見つかりませんでした。</div>
                    }
                    else
                    {
                        <div class="ic-template-list">
                            @foreach (var template in result.FeatureSummary.RepeatedDailyTemplates)
                            {
                                <article class="ic-template-card">
                                    <strong>@template.OccurrenceCount.ToString("N0") 日で完全一致</strong>
                                    <span>@string.Join(", ", template.Dates.Select(x => x.ToString("yyyy-MM-dd")))</span>
                                    <p>@template.ValuePattern</p>
                                </article>
                            }
                        </div>
                    }
                </section>
            </section>

            <section class="ic-section">
                <div class="ic-section-header">
                    <div>
                        <h2>CSVプレビュー</h2>
                        <p>アップロードした先頭 @result.PreviewRows.Count.ToString("N0") 行です。</p>
                    </div>
                </div>
                <div class="ic-table-wrap">
                    <table class="ic-table">
                        <thead>
                            <tr>
                                <th>調査日</th>
                                <th>顧客ID</th>
                                <th>漏れ電流</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in result.PreviewRows)
                            {
                                <tr>
                                    <td>@row.InvestigationDate.ToString("yyyy-MM-dd")</td>
                                    <td>@row.CustomerId</td>
                                    <td>@row.Current.ToString("0.00")mA</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </section>
        }
    </div>
</div>
