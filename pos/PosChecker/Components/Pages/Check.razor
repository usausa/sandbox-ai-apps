@page "/"
@rendermode InteractiveServer

<PageTitle>PosChecker</PageTitle>

<div class="ic">
    <div class="ic-actions">
        <div class="ic-dropzone-shell">
            <label class="ic-dropzone @(isBusy ? "is-busy" : string.Empty)"
                   title="担当者1名分の複数営業日トランザクションCSVをアップロード"
                   @ref="dropZoneRef">
                <div class="ic-dropzone-icon">
                    <i class="bi bi-file-earmark-arrow-up"></i>
                </div>
                <div class="ic-dropzone-copy">
                    <strong>トランザクションCSVをアップロード</strong>
                    <span>クリックして選択、またはこのエリアへCSVをドラッグ＆ドロップ</span>
                </div>
                <InputFile @key="inputFileKey" OnChange="OnCsvFileChangedAsync" accept=".csv,text/csv" class="ic-upload-input" disabled="@isBusy" />
            </label>
        </div>
        @if (result is not null && !isBusy)
        {
            <button type="button" class="btn-se-ghost" @onclick="ClearAsync">
                <i class="bi bi-trash3"></i>
                <span>結果をクリア</span>
            </button>
        }
        @if (isBusy)
        {
            <button type="button" class="btn-se-ghost" @onclick="CancelAsync">
                <i class="bi bi-stop-circle"></i>
                <span>キャンセル</span>
            </button>
        }
    </div>

    @if (errorMessage is not null)
    {
        <div class="fb-error-toast">
            <i class="bi bi-exclamation-circle"></i>
            <span>@errorMessage</span>
            <button type="button" class="btn-se-icon" @onclick="() => errorMessage = null">
                <i class="bi bi-x"></i>
            </button>
        </div>
    }

    @if (isBusy)
    {
        <div class="ig-progress">
            <div class="spinner-se spinner-se-lg" role="status"></div>
            <span class="ig-progress-message">@progressMessage</span>
        </div>
    }

    <div class="ic-content">
        @if (result is null)
        {
            <section class="ic-empty">
                <div class="ic-empty-icon">
                    <i class="bi bi-shield-exclamation"></i>
                </div>
                <h1>POSレジ操作ログから従業員の不正操作を検出</h1>
                <p>
                    トランザクションCSVをアップロードすると、取引種別の構成・取消/返品/ポイントの特徴量・シーケンス異常を先に集計し、
                    その要約と生データを Foundry の LLM に渡して不正確率を判定します。判定は「1営業日×1従業員」単位です。
                </p>
                <div class="ic-empty-format">
                    CSV列は <code>BusinessDate,CashierId,TransactionId,Time,Type,Amount,ItemCount,PaymentMethod,DiscountAmount,PointsEarned,PointsRedeemed,MembershipId,OriginalTransactionId,HasReceipt</code> です。
                </div>
            </section>

            <section class="ic-section">
                <div class="ic-section-header">
                    <div>
                        <h2>デモ用サンプルCSV</h2>
                        <p>正常2種、不正3種を用意しています。ローカルで保存してからアップロードしてください。</p>
                    </div>
                </div>
                <div class="ic-sample-grid">
                    @foreach (var sample in SampleFiles)
                    {
                        <a class="ic-sample-card" href="@sample.Url" download="@sample.FileName">
                            <span class="ic-sample-kind @sample.KindClass">@sample.KindLabel</span>
                            <strong>@sample.Title</strong>
                            <span>@sample.Description</span>
                        </a>
                    }
                </div>
            </section>
        }
        else
        {
            <section class="ic-overview">
                <article class="ic-score-card @GetScoreClass(result.Analysis.OverallScore)">
                    <span class="ic-score-label">不正確率</span>
                    <strong class="ic-score-value">@result.Analysis.OverallScore</strong>
                    <span class="ic-score-unit">/ 100</span>
                    <p>@GetScoreCaption(result.Analysis.OverallScore)</p>
                </article>

                <article class="ic-stat-card">
                    <h2>アップロード概要</h2>
                    <dl class="ic-stat-list">
                        <div><dt>ファイル</dt><dd>@result.UploadedFileName</dd></div>
                        <div><dt>取引数</dt><dd>@result.FeatureSummary.RecordCount.ToString("N0")</dd></div>
                        <div><dt>担当者</dt><dd>@result.FeatureSummary.CashierId</dd></div>
                        <div><dt>営業日数</dt><dd>@result.FeatureSummary.BusinessDayCount.ToString("N0")</dd></div>
                        <div><dt>期間</dt><dd>@result.FeatureSummary.StartDate.ToString("yyyy-MM-dd") ～ @result.FeatureSummary.EndDate.ToString("yyyy-MM-dd")</dd></div>
                    </dl>
                </article>

                <article class="ic-stat-card ic-summary-card">
                    <h2>LLMサマリー</h2>
                    <p>@result.Analysis.Summary</p>
                    <div class="ic-recommendation">
                        <i class="bi bi-lightbulb"></i>
                        <span>@result.Analysis.RecommendedAction</span>
                    </div>
                </article>
            </section>

            @if (result.Analysis.SuspiciousPatterns.Count > 0)
            {
                <section class="ic-section">
                    <div class="ic-section-header">
                        <div>
                            <h2>注目されたパターン</h2>
                            <p>LLM が不正兆候として重視した特徴です。</p>
                        </div>
                    </div>
                    <div class="ic-pattern-list">
                        @foreach (var pattern in result.Analysis.SuspiciousPatterns)
                        {
                            <span class="ic-pattern-chip">@pattern</span>
                        }
                    </div>
                </section>
            }

            <section class="ic-section">
                <div class="ic-section-header">
                    <div>
                        <h2>日別スコア</h2>
                        <p>高スコア日から並べています。1営業日＝1従業員の判定単位です。</p>
                    </div>
                </div>
                <div class="ic-table-wrap">
                    <table class="ic-table">
                        <thead>
                            <tr>
                                <th>営業日</th>
                                <th class="ic-col-score">スコア</th>
                                <th>機械集計の特徴</th>
                                <th>疑わしい取引</th>
                                <th>LLM理由</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var day in result.Analysis.DailyResults)
                            {
                                var feature = GetDailyFeature(day.BusinessDate);
                                <tr class="@GetRowClass(day.Score)">
                                    <td>@day.BusinessDate.ToString("yyyy-MM-dd")</td>
                                    <td class="ic-col-score">
                                        <span class="ic-score-pill @GetScoreClass(day.Score)">@day.Score</span>
                                    </td>
                                    <td>
                                        @if (feature is not null)
                                        {
                                            <div class="ic-feature-stack">
                                                <span>Void率 @FormatPercent(feature.VoidRatio)（@(feature.VoidCount)件） / 返金率 @FormatPercent(feature.ReturnRatio)（@(feature.ReturnCount)件）</span>
                                                <span>レシート無返品 @(feature.NoReceiptReturnCount)件 / 現金返金 @FormatYen(feature.CashReturnAmount)</span>
                                                <span>NoSale @(feature.NoSaleCount)件 / 値引率 @FormatPercent(feature.DiscountRatio)</span>
                                                <span>ポイント 利用 @feature.PointsRedeemed / 付与 @feature.PointsEarned</span>
                                                @if (feature.NonMemberPointsRedeemedCount > 0 || feature.PointsRedeemedCashCount > 0)
                                                {
                                                    <span>会員不在利用 @(feature.NonMemberPointsRedeemedCount)件 / 現金利用 @(feature.PointsRedeemedCashCount)件</span>
                                                }
                                                @if (feature.RedeemMembershipConcentration > 0 && feature.TopRedeemMembershipId is not null)
                                                {
                                                    <span>利用会員偏り @FormatPercent(feature.RedeemMembershipConcentration)（@feature.TopRedeemMembershipId）</span>
                                                }
                                                @if (feature.SaleThenVoidCount > 0)
                                                {
                                                    <span>売上直後取消 @(feature.SaleThenVoidCount)件</span>
                                                }
                                                @if (feature.AfterHoursCount > 0)
                                                {
                                                    <span>閑散帯操作 @(feature.AfterHoursCount)件</span>
                                                }
                                            </div>
                                        }
                                    </td>
                                    <td>
                                        @if (day.SuspiciousTransactionIds.Count == 0)
                                        {
                                            <span class="ic-muted">-</span>
                                        }
                                        else
                                        {
                                            <span>@string.Join(", ", day.SuspiciousTransactionIds)</span>
                                        }
                                    </td>
                                    <td>@day.Reason</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </section>

            <section class="ic-detail-grid">
                <section class="ic-section">
                    <div class="ic-section-header">
                        <div>
                            <h2>取引種別の構成</h2>
                            <p>取消・返品・レジ開放の比率が高いほど、現金操作の温床になりやすくなります。</p>
                        </div>
                    </div>
                    <div class="ic-table-wrap">
                        <table class="ic-table">
                            <thead>
                                <tr>
                                    <th>種別</th>
                                    <th>件数</th>
                                    <th>金額</th>
                                    <th>構成比</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var type in result.FeatureSummary.TypeDistribution)
                                {
                                    <tr>
                                        <td>@TypeLabel(type.Type)</td>
                                        <td>@type.Count.ToString("N0")</td>
                                        <td>@FormatYen(type.Amount)</td>
                                        <td>@FormatPercent(type.Ratio)</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </section>

                <section class="ic-section">
                    <div class="ic-section-header">
                        <div>
                            <h2>支払方法の構成</h2>
                            <p>現金は最も着服されやすいため、返金・ポイント利用の現金偏りに注目します。</p>
                        </div>
                    </div>
                    <div class="ic-table-wrap">
                        <table class="ic-table">
                            <thead>
                                <tr>
                                    <th>支払方法</th>
                                    <th>件数</th>
                                    <th>金額</th>
                                    <th>構成比</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var payment in result.FeatureSummary.PaymentDistribution)
                                {
                                    <tr>
                                        <td>@PaymentLabel(payment.Method)</td>
                                        <td>@payment.Count.ToString("N0")</td>
                                        <td>@FormatYen(payment.Amount)</td>
                                        <td>@FormatPercent(payment.Ratio)</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </section>
            </section>

            <section class="ic-section">
                <div class="ic-section-header">
                    <div>
                        <h2>検出されたシーケンス異常</h2>
                        <p>売上直後の取消・ポイント利用直後の取消・同額返品の反復などの並びを抽出します。</p>
                    </div>
                </div>
                @if (result.FeatureSummary.SequenceAnomalies.Count == 0)
                {
                    <div class="ic-placeholder">シーケンス異常は検出されませんでした。</div>
                }
                else
                {
                    <div class="ic-template-list">
                        @foreach (var anomaly in result.FeatureSummary.SequenceAnomalies)
                        {
                            <article class="ic-template-card">
                                <strong>@anomaly.Date.ToString("yyyy-MM-dd") ・ @AnomalyLabel(anomaly.Kind)</strong>
                                <p>@AnomalyDetail(anomaly)</p>
                            </article>
                        }
                    </div>
                }
            </section>

            <section class="ic-section">
                <div class="ic-section-header">
                    <div>
                        <h2>CSVプレビュー</h2>
                        <p>アップロードした先頭 @result.PreviewRows.Count.ToString("N0") 行です。</p>
                    </div>
                </div>
                <div class="ic-table-wrap">
                    <table class="ic-table">
                        <thead>
                            <tr>
                                <th>営業日</th>
                                <th>時刻</th>
                                <th>取引ID</th>
                                <th>種別</th>
                                <th>金額</th>
                                <th>支払</th>
                                <th>ポイント 利用/付与</th>
                                <th>会員</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in result.PreviewRows)
                            {
                                <tr>
                                    <td>@row.BusinessDate.ToString("yyyy-MM-dd")</td>
                                    <td>@row.Time.ToString("HH:mm:ss")</td>
                                    <td>@row.TransactionId</td>
                                    <td>@TypeLabel(row.Type)</td>
                                    <td>@FormatYen(row.Amount)</td>
                                    <td>@PaymentLabel(row.PaymentMethod)</td>
                                    <td>@row.PointsRedeemed / @row.PointsEarned</td>
                                    <td>@(row.MembershipId ?? "-")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </section>
        }
    </div>
</div>
