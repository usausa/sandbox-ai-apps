{
  "AllowedHosts": "*",

  "PosChecker": {
    "UploadPath": "./upload",
    "PreviewRowCount": 12,
    "ShortIntervalSeconds": 300,
    "MemberConcentrationThreshold": 0.3,
    "HighReturnRatioThreshold": 0.1,
    "HighRekeyRatioThreshold": 0.1,
    "RepeatedCouponMinOccurrences": 3,
    "SameItemMinOccurrences": 2,
    "BusinessHoursStartHour": 9,
    "BusinessHoursEndHour": 21,
    "ExcludeNonNormalRegister": true
  },

  "Foundry": {
    "Endpoint": "https://foundry-usausa-resource.services.ai.azure.com",
    "ApiKey": "",
    "ChatDeployment": "gpt-5.4-mini",
    "InputPricePer1M": 0.75,
    "OutputPricePer1M": 4.50,
    "UsdJpyRate": 160.4
  },

  "Serilog": {
    "Using": [
      "Serilog.Enrichers.Environment",
      "Serilog.Sinks.File"
    ],
    "Enrich": [ "FromLogContext", "WithThreadId", "WithMachineName" ],
    "MinimumLevel": {
      "Default": "Warning",
      "Override": {
        "Microsoft.Hosting.Lifetime": "Information",
        "PosChecker": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "path": "./log/PosChecker_.log",
          "rollingInterval": "Day",
          "outputTemplate": "{Timestamp:HH:mm:ss.fff} {Level:u4} {MachineName} [{SourceContext}] [{ThreadId}] - {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  }
}
