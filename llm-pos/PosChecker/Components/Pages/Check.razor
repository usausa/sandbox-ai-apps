@page "/"
@rendermode InteractiveServer

<PageTitle>PosChecker</PageTitle>

<div class="ic">
    <div class="ic-actions">
        <div class="ic-dropzone-shell">
            <label class="ic-dropzone @(isBusy ? "is-busy" : string.Empty)"
                   title="サンプルのZIP（3ビューCSVを内包）をそのままアップロード"
                   @ref="dropZoneRef">
                <div class="ic-dropzone-icon">
                    <i class="bi bi-file-earmark-zip"></i>
                </div>
                <div class="ic-dropzone-copy">
                    <strong>サンプルZIPをアップロード</strong>
                    <span>ダウンロードしたZIP（SalesHeader / SalesDetail / Promotion を内包）を選択、またはドラッグ＆ドロップ</span>
                </div>
                <InputFile @key="inputFileKey" OnChange="OnUploadAsync" accept=".zip,.csv" multiple class="ic-upload-input" disabled="@isBusy" />
            </label>
        </div>
        @if (result is not null && !isBusy)
        {
            <button type="button" class="btn-se-ghost" @onclick="ClearAsync">
                <i class="bi bi-trash3"></i>
                <span>結果をクリア</span>
            </button>
        }
        @if (isBusy)
        {
            <button type="button" class="btn-se-ghost" @onclick="CancelAsync">
                <i class="bi bi-stop-circle"></i>
                <span>キャンセル</span>
            </button>
        }
    </div>

    @if (errorMessage is not null)
    {
        <div class="fb-error-toast">
            <i class="bi bi-exclamation-circle"></i>
            <span>@errorMessage</span>
            <button type="button" class="btn-se-icon" @onclick="() => errorMessage = null">
                <i class="bi bi-x"></i>
            </button>
        </div>
    }

    @if (isBusy)
    {
        <div class="ig-progress">
            <div class="spinner-se spinner-se-lg" role="status"></div>
            <span class="ig-progress-message">@progressMessage</span>
        </div>
    }

    <div class="ic-content">
        @if (result is null)
        {
            <section class="ic-empty">
                <div class="ic-empty-icon">
                    <i class="bi bi-shield-exclamation"></i>
                </div>
                <h1>POSトランザクションから不正一覧の5事象を検出</h1>
                <p>
                    3ビューCSV（SalesHeader / SalesDetail / Promotion）を内包したZIPをアップロードすると、担当者×店舗・会員の特徴量を先に集計し、
                    その要約と生データを Foundry の LLM に渡して不正確率を判定します。判定は「店舗×担当者」を主軸に、ポイント/クーポン不正は会員も評価します。
                </p>
                <div class="ic-empty-format">
                    対象事象: <code>ポイント不正付与 / かご抜け / クーポン不正利用 / フリー返品不正 / 打ち直し不正</code>
                </div>
            </section>

            <section class="ic-section">
                <div class="ic-section-header">
                    <div>
                        <h2>デモ用サンプルCSV</h2>
                        <p>各セットは3ビューCSVを内包したZIPです。ダウンロードして、そのままアップロードしてください。</p>
                    </div>
                </div>
                <div class="ic-sample-grid">
                    @foreach (var sample in SampleSets)
                    {
                        <a class="ic-sample-card" href="@($"{sample.BaseUrl}/download")">
                            <span class="ic-sample-kind @sample.KindClass">@sample.KindLabel</span>
                            <strong>@sample.Title</strong>
                            <span>@sample.Description</span>
                            <span class="ic-sample-download"><i class="bi bi-download"></i> ダウンロード (ZIP)</span>
                        </a>
                    }
                </div>
            </section>
        }
        else
        {
            <section class="ic-overview">
                <article class="ic-score-card @GetScoreClass(result.Analysis.OverallScore)">
                    <span class="ic-score-label">不正確率</span>
                    <strong class="ic-score-value">@result.Analysis.OverallScore</strong>
                    <span class="ic-score-unit">/ 100</span>
                    <p>@GetScoreCaption(result.Analysis.OverallScore)</p>
                </article>

                <article class="ic-stat-card">
                    <h2>アップロード概要</h2>
                    <dl class="ic-stat-list">
                        <div><dt>取引数</dt><dd>@result.FeatureSummary.TransactionCount.ToString("N0")</dd></div>
                        <div><dt>店舗 / 担当者</dt><dd>@result.FeatureSummary.StoreCount / @result.FeatureSummary.CashierCount</dd></div>
                        <div><dt>会員数</dt><dd>@result.FeatureSummary.MemberCount.ToString("N0")</dd></div>
                        <div><dt>期間</dt><dd>@result.FeatureSummary.StartDate.ToString("yyyy-MM-dd") ～ @result.FeatureSummary.EndDate.ToString("yyyy-MM-dd")</dd></div>
                        <div><dt>トークン</dt><dd>@FormatTokens(result.Usage)</dd></div>
                        <div><dt>概算費用</dt><dd>@FormatCost(result.Usage)</dd></div>
                    </dl>
                </article>

                <article class="ic-stat-card ic-summary-card">
                    <h2>LLMサマリー</h2>
                    <p>@result.Analysis.Summary</p>
                    <div class="ic-recommendation">
                        <i class="bi bi-lightbulb"></i>
                        <span>@result.Analysis.RecommendedAction</span>
                    </div>
                </article>
            </section>

            @if (result.Analysis.SuspiciousPatterns.Count > 0)
            {
                <section class="ic-section">
                    <div class="ic-section-header">
                        <div>
                            <h2>注目されたパターン</h2>
                            <p>LLM が不正兆候として重視した特徴です。</p>
                        </div>
                    </div>
                    <div class="ic-pattern-list">
                        @foreach (var pattern in result.Analysis.SuspiciousPatterns)
                        {
                            <span class="ic-pattern-chip">@pattern</span>
                        }
                    </div>
                </section>
            }

            <section class="ic-section">
                <div class="ic-section-header">
                    <div>
                        <h2>担当者スコア（店舗×担当者）</h2>
                        <p>高スコア順に並べています。担当者単位が判定の主軸です。</p>
                    </div>
                </div>
                <div class="ic-table-wrap">
                    <table class="ic-table">
                        <thead>
                            <tr>
                                <th>店舗 / 担当者</th>
                                <th class="ic-col-score">スコア</th>
                                <th>機械集計の特徴</th>
                                <th>該当事象</th>
                                <th>LLM理由</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var cashier in result.Analysis.CashierResults)
                            {
                                var feature = GetCashierFeature(cashier.StoreCode, cashier.CashierCode);
                                <tr class="@GetRowClass(cashier.Score)">
                                    <td>
                                        <div class="ic-feature-stack">
                                            <span>@cashier.StoreCode / @cashier.CashierCode</span>
                                            <span class="ic-muted">@cashier.CashierName</span>
                                        </div>
                                    </td>
                                    <td class="ic-col-score">
                                        <span class="ic-score-pill @GetScoreClass(cashier.Score)">@cashier.Score</span>
                                    </td>
                                    <td>
                                        @if (feature is not null)
                                        {
                                            <div class="ic-feature-stack">
                                                <span>取引 @(feature.TransactionCount)件 / 売上 @(feature.SalesCount)件</span>
                                                <span>返品 @(feature.ReturnCount)件（率 @FormatPercent(feature.ReturnRatio) / @FormatYen(feature.ReturnAmount)） / 打直 @(feature.RekeyCount)件（率 @FormatPercent(feature.RekeyRatio)）</span>
                                                @if (feature.TopMemberCode is not null && feature.MemberConcentration > 0)
                                                {
                                                    <span>会員偏り @FormatPercent(feature.MemberConcentration)（@feature.TopMemberCode / @(feature.TopMemberSalesCount)件）</span>
                                                }
                                                @if (feature.SameItemRepeatCount > 0)
                                                {
                                                    <span>同一商品複数購入 @(feature.SameItemRepeatCount)件</span>
                                                }
                                                @if (feature.ShortIntervalSameMemberCount > 0)
                                                {
                                                    <span>短時間連続会計 @(feature.ShortIntervalSameMemberCount)件</span>
                                                }
                                                @if (feature.AfterHoursReturnRekeyCount > 0)
                                                {
                                                    <span>営業時間外の返品/打直 @(feature.AfterHoursReturnRekeyCount)件</span>
                                                }
                                            </div>
                                        }
                                    </td>
                                    <td>
                                        @if (cashier.Scenarios.Count == 0)
                                        {
                                            <span class="ic-muted">-</span>
                                        }
                                        else
                                        {
                                            <div class="ic-pattern-list">
                                                @foreach (var scenario in cashier.Scenarios)
                                                {
                                                    <span class="ic-pattern-chip">@ScenarioLabel(scenario)</span>
                                                }
                                            </div>
                                        }
                                    </td>
                                    <td>@cashier.Reason</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </section>

            @if (result.Analysis.MemberResults.Count > 0)
            {
                <section class="ic-section">
                    <div class="ic-section-header">
                        <div>
                            <h2>会員フラグ（ポイント/クーポン不正）</h2>
                            <p>ポイント不正付与・クーポン反復利用の疑いがある会員です。</p>
                        </div>
                    </div>
                    <div class="ic-table-wrap">
                        <table class="ic-table">
                            <thead>
                                <tr>
                                    <th>会員</th>
                                    <th class="ic-col-score">スコア</th>
                                    <th>該当事象</th>
                                    <th>LLM理由</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var member in result.Analysis.MemberResults)
                                {
                                    <tr class="@GetRowClass(member.Score)">
                                        <td>@member.MemberCode</td>
                                        <td class="ic-col-score">
                                            <span class="ic-score-pill @GetScoreClass(member.Score)">@member.Score</span>
                                        </td>
                                        <td>
                                            <div class="ic-pattern-list">
                                                @foreach (var scenario in member.Scenarios)
                                                {
                                                    <span class="ic-pattern-chip">@ScenarioLabel(scenario)</span>
                                                }
                                            </div>
                                        </td>
                                        <td>@member.Reason</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </section>
            }

            <section class="ic-detail-grid">
                <section class="ic-section">
                    <div class="ic-section-header">
                        <div>
                            <h2>取引種別の構成</h2>
                            <p>返品の比率が高い担当者・店舗ほど現金操作の温床になりやすくなります。</p>
                        </div>
                    </div>
                    <div class="ic-table-wrap">
                        <table class="ic-table">
                            <thead>
                                <tr>
                                    <th>種別</th>
                                    <th>件数</th>
                                    <th>金額</th>
                                    <th>構成比</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var type in result.FeatureSummary.TypeDistribution)
                                {
                                    <tr>
                                        <td>@TypeLabel(type.Type)</td>
                                        <td>@type.Count.ToString("N0")</td>
                                        <td>@FormatYen(type.Amount)</td>
                                        <td>@FormatPercent(type.Ratio)</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </section>

                <section class="ic-section">
                    <div class="ic-section-header">
                        <div>
                            <h2>金種の構成</h2>
                            <p>現金は最も着服されやすいため、返品・ポイント利用の現金偏りに注目します。</p>
                        </div>
                    </div>
                    <div class="ic-table-wrap">
                        <table class="ic-table">
                            <thead>
                                <tr>
                                    <th>金種</th>
                                    <th>件数</th>
                                    <th>金額</th>
                                    <th>構成比</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var tender in result.FeatureSummary.TenderDistribution)
                                {
                                    <tr>
                                        <td>@TenderLabel(tender.Tender)</td>
                                        <td>@tender.Count.ToString("N0")</td>
                                        <td>@FormatYen(tender.Amount)</td>
                                        <td>@FormatPercent(tender.Ratio)</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </section>
            </section>

            <section class="ic-section">
                <div class="ic-section-header">
                    <div>
                        <h2>検出された不正シグナル</h2>
                        <p>担当者の会員偏り・同一商品複数購入・クーポン反復・高返品率/打直率などを決定論的に抽出します。</p>
                    </div>
                </div>
                @if (result.FeatureSummary.FraudSignals.Count == 0)
                {
                    <div class="ic-placeholder">不正シグナルは検出されませんでした。</div>
                }
                else
                {
                    <div class="ic-template-list">
                        @foreach (var signal in result.FeatureSummary.FraudSignals)
                        {
                            <article class="ic-template-card">
                                <strong>@SignalLabel(signal.Kind)</strong>
                                <p>
                                    店舗 @signal.StoreCode
                                    @if (signal.CashierCode is not null)
                                    {
                                        <span> ・ 担当者 @signal.CashierCode</span>
                                    }
                                    @if (signal.MemberCode is not null)
                                    {
                                        <span> ・ 会員 @signal.MemberCode</span>
                                    }
                                </p>
                                <p>@signal.Detail</p>
                            </article>
                        }
                    </div>
                }
            </section>

            <section class="ic-section">
                <div class="ic-section-header">
                    <div>
                        <h2>売上CSVプレビュー</h2>
                        <p>アップロードした先頭 @result.PreviewTransactions.Count.ToString("N0") 取引です。</p>
                    </div>
                </div>
                <div class="ic-table-wrap">
                    <table class="ic-table">
                        <thead>
                            <tr>
                                <th>店舗</th>
                                <th>日付</th>
                                <th>時刻</th>
                                <th>担当者</th>
                                <th>種別</th>
                                <th>金種</th>
                                <th>金額</th>
                                <th>会員</th>
                                <th>明細数</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var tx in result.PreviewTransactions)
                            {
                                <tr>
                                    <td>@tx.Header.StoreCode</td>
                                    <td>@tx.Header.SalesDate.ToString("yyyy-MM-dd")</td>
                                    <td>@tx.Header.SystemTime.ToString("HH:mm:ss")</td>
                                    <td>@tx.Header.CashierCode</td>
                                    <td>@TypeLabel(tx.Header.TransactionType)</td>
                                    <td>@TenderLabel(tx.Header.TenderType)</td>
                                    <td>@FormatYen(tx.Header.TotalAmount)</td>
                                    <td>@(tx.Header.MemberCode ?? "-")</td>
                                    <td>@tx.Details.Count</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </section>
        }
    </div>
</div>
